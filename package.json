{
  "name": "qltt-monorepo",
  "private": true,
  "type": "module",
  "description": "QLTT — monorepo backend + frontend",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:services": "concurrently -k -n API,WEB -c blue,green \"node backend/scripts/start-backend.js\" \"npm run dev -w qltt-frontend\"",
    "start": "npm run dev",
    "setup": "node scripts/setup.js",
    "env:copy": "node scripts/copy-env.js",
    "be": "node backend/scripts/start-backend.js",
    "fe": "npm run dev -w qltt-frontend",
    "build": "npm run build -w qltt-frontend",
    "db:migrate": "node backend/scripts/migrate.js",
    "db:up": "docker compose --env-file .env -f backend/docker-compose.yml up -d sqlserver",
    "db:down": "docker compose -f backend/docker-compose.yml down",
    "db:logs": "docker compose -f backend/docker-compose.yml logs -f sqlserver",
    "check:api": "node backend/scripts/check-api.js",
    "verify:db": "node backend/scripts/verify-database.js",
    "postinstall": "node scripts/postinstall.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
