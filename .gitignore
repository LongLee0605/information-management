# ---------------------------
# Security: environment files
# ---------------------------
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local
**/.env.*
!**/.env.example

# ---------------------------
# Security: secrets/certs/keys
# ---------------------------
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.jks
*.keystore
*.asc

# ---------------------------
# Security: dumps/logs/backups
# ---------------------------
*.log
logs/
**/logs/
*.sqlite
*.sqlite3
*.db
*.bak
*.dump
*.sql.gz
*.tgz
*.zip

# ---------------------------
# Build/dependency outputs
# ---------------------------
node_modules/
**/node_modules/
dist/
**/dist/
dist-ssr/
coverage/

# ---------------------------
# IDE/OS files
# ---------------------------
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------------------------
# Local-only documents
# ---------------------------
docs/
plans/
*.xlsx
